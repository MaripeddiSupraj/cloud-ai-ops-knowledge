# LinkedIn credentials (used by linkedin-api to fetch post content)
# Copy this file to .env and fill in your values
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Ollama model to use for enrichment (must be pulled: ollama pull llama3)
OLLAMA_MODEL=llama3

# Ollama server URL (default — only change if you run Ollama on a custom port)
OLLAMA_BASE_URL=http://localhost:11434
